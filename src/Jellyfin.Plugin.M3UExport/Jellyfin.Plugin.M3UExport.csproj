<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Jellyfin.Plugin.M3UExport</RootNamespace>
    <AssemblyName>Jellyfin.Plugin.M3UExport</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Version>1.0.0.7</Version>
    <NoWarn>$(NoWarn);CS1591;SA1633;SA1600</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Jellyfin.Common" Version="10.10.0" ExcludeAssets="runtime" />
    <PackageReference Include="Jellyfin.Controller" Version="10.10.0" ExcludeAssets="runtime" />
    <PackageReference Include="Jellyfin.Model" Version="10.10.0" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Configuration/config.html" />
  </ItemGroup>

</Project>
